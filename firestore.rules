rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Notifications - Server-side writes, client can read and update read status
    match /notifications/{notificationId} {
      // Allow read if the notification belongs to the requesting user
      allow read: if true; // Client can read (filter by userId in client code)
      allow create, delete: if false; // Only server (Admin SDK) can create/delete
      // Allow client to update only the 'read' field
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
    }
    
    // FCM Tokens - Server-side only (Firebase Admin SDK)
    match /fcmTokens/{userId} {
      allow read: if true; // Client can read their own token
      allow write: if false; // Only server (Admin SDK) can write
    }
    
    // Default: deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
