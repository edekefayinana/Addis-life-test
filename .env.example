# NextAuth Configuration
NEXTAUTH_SECRET="your-nextauth-secret-here"
NEXTAUTH_URL="https://your-domain.vercel.app"

# Database
DATABASE_URL="your-postgres-connection-string"

# SMTP Configuration (Mailtrap or your email service - for development)
SMTP_USER="your-smtp-user"
SMTP_PASS="your-smtp-password"
SMTP_HOST="your-smtp-host"
SMTP_PORT="587"
SMTP_FROM="your-email@example.com"

# API URLs
API_BASE_URL="https://your-domain.vercel.app/api"
NEXT_PUBLIC_API_BASE_URL="https://your-domain.vercel.app/api"
NEXT_PUBLIC_API_URL="https://your-domain.vercel.app/api"

# Resend (Email Service - for production)
RESEND_API_KEY="your-resend-api-key"
RESEND_FROM="Your App <noreply@your-domain.com>"

# Contact Email
CONTACT_EMAIL="your-contact@example.com"

# Cloudinary (File Upload Service)
CLOUDINARY_CLOUD_NAME="your-cloudinary-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloudinary-cloud-name"

# Firebase Configuration
FIREBASE_PROJECT_ID="your-firebase-project-id"
FIREBASE_CLIENT_EMAIL="your-firebase-client-email"
FIREBASE_PRIVATE_KEY="your-firebase-private-key"
FIREBASE_SERVICE_ACCOUNT='your-firebase-service-account-json'
NEXT_PUBLIC_FIREBASE_VAPID_KEY="your-firebase-vapid-key"

# Environment
NODE_ENV="production"
