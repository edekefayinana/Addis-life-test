// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String         @id @default(cuid())
  name            String?
  email           String         @unique
  phone           String?
  emailVerified   DateTime?
  image           String?
  password        String
  role            Role           @default(AGENT)
  approvalStatus  ApprovalStatus @default(APPROVED)
  governmentIdUrl String?
  accounts        Account[]
  sessions        Session[]
  properties      Property[]
  reservations    Reservation[]
  notifications   Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
  @@index([approvalStatus])
  @@index([createdAt])
}

enum Role {
  ADMIN
  AGENT
}

enum ApprovalStatus {
  PENDING
  APPROVED
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String                @unique
  expires    DateTime
  type       VerificationTokenType @default(EMAIL)
  otp        Int?

  @@unique([identifier, token])
  @@index([identifier])
  @@index([type])
}

enum VerificationTokenType {
  EMAIL
  PASSWORD_RESET
  OTP
}

enum PropertyType {
  APARTMENT
  HOUSE
  VILLA
  CONDO
  COMMERCIAL
}

enum PropertyListingType {
  RENT
  SALE
}

model Project {
  id         String     @id @default(uuid())
  name       String
  properties Property[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model Property {
  id    String @id @default(uuid())
  title String

  // Overview
  builtStartDate DateTime
  propertyType   PropertyType
  listingType    PropertyListingType
  currentStatus  String

  // Property Details
  totalBedrooms   Int
  totalBathrooms  Int
  parkingSpace    Int
  areaSizeM2      Float
  availableFloors Json
  buildingSize    String
  deliveryTime    String

  // Location
  address   String
  city      String
  country   String
  longitude Float
  latitude  Float

  // 🔗 Relation to User (ADMIN)
  createdBy   User   @relation(fields: [createdById], references: [id])
  createdById String

  // 🔗 Relation to Project
  project   Project @relation(fields: [projectId], references: [id])
  projectId String

  // Relations
  amenities    Amenity[]
  nearbyPlaces NearbyPlace[]
  images       PropertyImage[]
  reservations Reservation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([propertyType])
  @@index([listingType])
  @@index([city])
  @@index([createdById])
  @@index([projectId])
  @@index([createdAt])
  @@index([propertyType, listingType])
}

model Amenity {
  id         String   @id @default(uuid())
  name       String
  property   Property @relation(fields: [propertyId], references: [id])
  propertyId String

  @@index([propertyId])
}

model NearbyPlace {
  id         String   @id @default(uuid())
  name       String
  property   Property @relation(fields: [propertyId], references: [id])
  propertyId String

  @@index([propertyId])
}

model PropertyImage {
  id         String   @id @default(uuid())
  url        String
  property   Property @relation(fields: [propertyId], references: [id])
  propertyId String

  @@index([propertyId])
}

model Reservation {
  id          String            @id @default(uuid())
  user        User              @relation(fields: [userId], references: [id])
  userId      String
  property    Property          @relation(fields: [propertyId], references: [id])
  propertyId  String
  status      ReservationStatus @default(PENDING)
  description String?
  createdAt   DateTime          @default(now())
  expiresAt   DateTime
  confirmedAt DateTime?
  cancelledAt DateTime?

  @@index([userId])
  @@index([propertyId])
  @@index([status])
  @@index([createdAt])
  @@index([expiresAt])
  @@index([propertyId, status])
  @@index([userId, status])
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  EXPIRED
  SELLED
}

model Notification {
  id        String           @id @default(uuid())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  title     String
  body      String
  type      NotificationType @default(SYSTEM)
  read      Boolean          @default(false)
  link      String?
  data      Json?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([userId])
  @@index([read])
  @@index([type])
  @@index([createdAt])
  @@index([userId, read])
  @@index([userId, createdAt])
}

enum NotificationType {
  COMMISSION
  RESERVATION
  ASSET
  SYSTEM
  PROFILE
}
