generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String         @id @default(cuid())
  name            String?
  email           String         @unique
  phone           String?
  emailVerified   DateTime?
  image           String?
  password        String
  role            Role           @default(AGENT)
  approvalStatus  ApprovalStatus @default(APPROVED)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  governmentIdUrl String?
  accounts        Account[]
  notifications   Notification[]
  properties      Property[]
  reservations    Reservation[]
  sessions        Session[]

  @@index([role])
  @@index([approvalStatus])
  @@index([createdAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String                @unique
  expires    DateTime
  type       VerificationTokenType @default(EMAIL)
  otp        Int?

  @@unique([identifier, token])
  @@index([identifier])
  @@index([type])
}

model Project {
  id           String         @id @default(uuid())
  name         String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  pdfUrl       String?
  properties   Property[]
  siteProgress SiteProgress[]
}

model Property {
  id              String              @id @default(uuid())
  title           String
  builtStartDate  DateTime
  propertyType    PropertyType
  listingType     PropertyListingType
  currentStatus   String
  totalBedrooms   Int
  totalBathrooms  Int
  parkingSpace    Int
  areaSizeM2      Float
  availableFloors Json
  buildingSize    String
  deliveryTime    String
  address         String
  city            String
  country         String
  longitude       Float
  latitude        Float
  createdById     String
  projectId       String
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  amenities       Amenity[]
  nearbyPlaces    NearbyPlace[]
  createdBy       User                @relation(fields: [createdById], references: [id])
  project         Project             @relation(fields: [projectId], references: [id])
  images          PropertyImage[]
  reservations    Reservation[]

  @@index([propertyType])
  @@index([listingType])
  @@index([city])
  @@index([createdById])
  @@index([projectId])
  @@index([createdAt])
  @@index([propertyType, listingType])
}

model Amenity {
  id         String   @id @default(uuid())
  name       String
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id])

  @@index([propertyId])
}

model NearbyPlace {
  id         String   @id @default(uuid())
  name       String
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id])

  @@index([propertyId])
}

model PropertyImage {
  id         String   @id @default(uuid())
  url        String
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id])

  @@index([propertyId])
}

model Reservation {
  id                 String            @id @default(uuid())
  userId             String
  propertyId         String
  status             ReservationStatus @default(PENDING)
  description        String?
  createdAt          DateTime          @default(now())
  expiresAt          DateTime
  confirmedAt        DateTime?
  cancelledAt        DateTime?
  bankSlipUrl        String?
  clientEmail        String?
  clientGovernmentId String?
  clientName         String
  clientPhone        String
  reservationAmount  Float
  property           Property          @relation(fields: [propertyId], references: [id])
  user               User              @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([propertyId])
  @@index([status])
  @@index([createdAt])
  @@index([expiresAt])
  @@index([propertyId, status])
  @@index([userId, status])
  @@index([clientPhone])
  @@index([clientEmail])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  title     String
  body      String
  type      NotificationType @default(SYSTEM)
  read      Boolean          @default(false)
  link      String?
  data      Json?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
  @@index([type])
  @@index([createdAt])
  @@index([userId, read])
  @@index([userId, createdAt])
}

enum Role {
  ADMIN
  AGENT
}

enum ApprovalStatus {
  PENDING
  APPROVED
}

enum VerificationTokenType {
  EMAIL
  PASSWORD_RESET
  OTP
}

enum PropertyType {
  APARTMENT
  HOUSE
  VILLA
  CONDO
  COMMERCIAL
}

enum PropertyListingType {
  RENT
  SALE
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  EXPIRED
  SELLED
}

enum NotificationType {
  COMMISSION
  RESERVATION
  ASSET
  SYSTEM
  PROFILE
}

model SiteProgress {
  id          String         @id @default(uuid())
  title       String
  description String?
  projectId   String
  status      ProgressStatus @default(IN_PROGRESS)
  publishedAt DateTime?
  order       Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  media       ProgressMedia[]
  project     Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([status])
  @@index([publishedAt])
  @@index([projectId, publishedAt])
  @@index([order])
}

model ProgressMedia {
  id             String       @id @default(uuid())
  url            String
  type           MediaType
  thumbnailUrl   String?
  caption        String?
  order          Int          @default(0)
  siteProgressId String
  createdAt      DateTime     @default(now())
  siteProgress   SiteProgress @relation(fields: [siteProgressId], references: [id], onDelete: Cascade)

  @@index([siteProgressId])
  @@index([order])
}

enum ProgressStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
}

enum MediaType {
  IMAGE
  VIDEO
}
